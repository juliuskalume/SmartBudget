# Exchange Rate API Key (https://www.exchangerate-api.com)
# Used as a fallback when Frankfurter API is unavailable or rate limits are hit.
# Get your free API key at: https://app.exchangerate-api.com/sign-up
# IMPORTANT: Keep this server-side only - never expose to client
EXCHANGERATE_API_KEY="your-exchangerate-api-key"

# Supabase powers login and cloud persistence.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# GROQ_API_KEY powers the optional AI categorization and advice routes.
GROQ_API_KEY="your-groq-api-key"

# TWELVE_DATA_API_KEY is optional and used as a secondary market-data backup if Yahoo is unavailable.
TWELVE_DATA_API_KEY="your-twelve-data-api-key"

# SUPABASE_SERVICE_ROLE_KEY is required on the server for secure account deletion.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# APP_URL optionally overrides the hosted client URL used by the Android wrapper.
# If omitted, the Android app defaults to the production client URL.
APP_URL="https://your-app.vercel.app"
